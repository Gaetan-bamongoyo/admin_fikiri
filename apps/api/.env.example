# Server
PORT=7540
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fikiri_traffic
# Docker: start PostgreSQL with `pnpm docker:db` from the repo root, then use DB_HOST=localhost
# Set to true only for quick local prototyping (prefer migrations)
DB_SYNCHRONIZE=false
# Run pending migrations automatically on app startup
DB_RUN_MIGRATIONS=false

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Cloudinary (optional — for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Notifications push (api_python)
PYTHON_API_URL=http://localhost:8000
NOTIFICATIONS_INTERNAL_SECRET=dev-internal-secret-fikiri
# Fréquence cron alertes intelligentes (minutes) — prod test rapide : 3
ALERTS_CRON_INTERVAL_MINUTES=5
