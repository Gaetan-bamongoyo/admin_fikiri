# URL de l'API backend (préfixe /api/v1 inclus).
# Local : copier en .env.local
# Vercel : Project Settings → Environment Variables
#
# Production (API en HTTP sur un VPS) — le proxy Next.js évite le mixed content :
NEXT_PUBLIC_API_URL=http://VOTRE_IP:7540/api/v1
# Optionnel si différent de NEXT_PUBLIC_API_URL :
# API_UPSTREAM_URL=http://VOTRE_IP:7540/api/v1
#
# Local :
# NEXT_PUBLIC_API_URL=http://localhost:7540/api/v1

# Optionnel — tuiles carte (défaut : CARTO Voyager)
# NEXT_PUBLIC_MAP_TILES_URL=...

# Optionnel — routing OSRM
# NEXT_PUBLIC_OSRM_URL=...
