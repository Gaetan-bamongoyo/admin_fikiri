{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@fikiri/ui/components/*": ["../../packages/ui/src/components/*"],
      "@fikiri/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@fikiri/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@fikiri/ui/globals.css": ["../../packages/ui/src/styles/globals.css"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
